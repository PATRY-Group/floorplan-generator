# Python bytecode
__pycache__/
*.pyc

# Backend virtualenv + transient runtime data (not source)
app/backend/.venv/
app/backend/data/uploads/
app/backend/data/sheets/

# Node / Vite
app/frontend/node_modules/
app/frontend/dist/

# Large CAD source files — reference samples only, never processed by the app
*.rvt

.vercel
.env*

# uv project files are now TRACKED: uv.lock pins the exact dependency set for
# reproducible backend builds, .python-version pins the interpreter, and
# pyproject.toml is the project definition. (The Vercel/Docker builds still
# install from requirements.txt, but the lock records the resolved versions.)
